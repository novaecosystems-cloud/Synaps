generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

model Organization {
  id                      String                   @id @default(uuid())
  name                    String
  settings                Json?                    @default("{}")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  users                   User[]
  invitations             Invitation[]
  projects                Project[]
  documents               Document[]
  gaps                    Gap[]
  decisions               Decision[]
  executiveSummaries      ExecutiveSummary[]
  proposals               Proposal[]
  auditLogs               AuditLog[]
  exportJobs              ExportJob[]
  projectMembers          ProjectMember[]
  projectTasks            ProjectTask[]
  taskNotes               TaskNote[]
  documentVersions        DocumentVersion[]
  processingJobs          ProcessingJob[]
  processedDocuments      ProcessedDocument[]
  documentMetadata        DocumentMetadata[]
  documentChunks          DocumentChunk[]
  requirements            Requirement[]
  proposalSections        ProposalSection[]
  approvalRequests        ApprovalRequest[]
  approvalComments        ApprovalComment[]
  notificationPreferences NotificationPreference[]
  connectors              Connector[]
  chatSessions            ChatSession[]
  agents                  Agent[]
  promptTemplates         PromptTemplate[]
  workflows               Workflow[]
  modelSettings           ModelSetting[]
  graphEntities           GraphEntity[]
  graphRelationships      GraphRelationship[]
}

model User {
  id                     String                  @id // Firebase UID
  email                  String                  @unique
  name                   String?
  avatarUrl              String?
  role                   Role                    @default(MEMBER)
  organizationId         String?
  organization           Organization?           @relation(fields: [organizationId], references: [id])
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  ownedProjects          Project[]               @relation("ProjectOwner")
  projectMembers         ProjectMember[]
  taskNotes              TaskNote[]
  documents              Document[]
  uploadedVersions       DocumentVersion[]
  approvalRequests       ApprovalRequest[]
  approvalComments       ApprovalComment[]
  auditLogs              AuditLog[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  searchHistory          SearchHistory[]
  savedSearches          SavedSearch[]
  exportJobs             ExportJob[]
  chatSessions           ChatSession[]

  @@index([organizationId])
}

model Invitation {
  id             String        @id @default(uuid())
  email          String
  role           Role          @default(MEMBER)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  token          String        @unique
  status         String        @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  expiresAt      DateTime
  invitedBy      String // Firebase UID of the inviter
  createdAt      DateTime      @default(now())

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([token])
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ProjectRole {
  MANAGER
  EDITOR
  VIEWER
}

model Project {
  id                 String             @id @default(uuid())
  name               String
  description        String?
  status             ProjectStatus      @default(DRAFT)
  metadata           Json?              @default("{}") // Budget, dates, etc
  organizationId     String?
  organization       Organization?      @relation(fields: [organizationId], references: [id])
  ownerId            String
  owner              User               @relation("ProjectOwner", fields: [ownerId], references: [id])
  isDeleted          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  members            ProjectMember[]
  tasks              ProjectTask[]
  documents          Document[]
  gaps               Gap[]
  decisions          Decision[]
  executiveSummaries ExecutiveSummary[]
  proposals          Proposal[]
  chatSessions       ChatSession[]
  workspaceDocuments ProjectDocument[]

  @@index([organizationId])
  @@index([ownerId])
}

model ProjectMember {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           ProjectRole   @default(VIEWER)
  createdAt      DateTime      @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([organizationId])
}

enum TaskStatus {
  INCOMPLETE
  ACTIVE
  DONE
}

model ProjectTask {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  status         TaskStatus    @default(INCOMPLETE)
  deadline       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  notes          TaskNote[]

  @@index([projectId])
  @@index([organizationId])
}

model TaskNote {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  taskId         String
  task           ProjectTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime      @default(now())

  @@index([taskId])
  @@index([userId])
  @@index([organizationId])
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
  BYPASSED
}

model Document {
  id             String        @id @default(uuid())
  name           String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])
  ownerId        String
  owner          User          @relation(fields: [ownerId], references: [id])

  currentVersionId String?
  mimeType         String
  sizeBytes        Int
  scanStatus       ScanStatus @default(PENDING)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions         DocumentVersion[]
  processingJob    ProcessingJob?
  processedDoc     ProcessedDocument?
  metadata         DocumentMetadata[]
  chunks           DocumentChunk[]
  requirements     Requirement[]
  gaps             Gap[]
  decision         Decision?
  executiveSummary ExecutiveSummary?
  proposal         Proposal?

  connectorId      String?
  connector        Connector?        @relation("ConnectorDocuments", fields: [connectorId], references: [id])
  citations        MessageCitation[]
  workspaceDocuments ProjectDocument[]
  graphEntities    GraphEntity[]
  graphRelationships GraphRelationship[]

  @@index([organizationId])
  @@index([projectId])
  @@index([organizationId, projectId])
}

model DocumentVersion {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String
  document       Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNum     Int
  storagePath    String
  originalName   String
  mimeType       String
  sizeBytes      Int
  scanStatus     ScanStatus    @default(PENDING)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([organizationId])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ProcessingJob {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String        @unique
  document       Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  status         JobStatus     @default(PENDING)
  progress       Int           @default(0)
  attempts       Int           @default(0)
  error          String?       @db.Text
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model ProcessedDocument {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String        @unique
  document       Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  textContent    String        @db.Text
  pageCount      Int           @default(0)
  detectedType   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model DocumentMetadata {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String
  document       Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  key            String
  value          String        @db.Text
  createdAt      DateTime      @default(now())

  @@unique([documentId, key])
  @@index([documentId])
  @@index([organizationId])
}

enum ChunkType {
  TEXT
  TABLE
  IMAGE
  HEADER
}

model DocumentChunk {
  id             String                       @id @default(uuid())
  organizationId String?
  organization   Organization?                @relation(fields: [organizationId], references: [id])
  documentId     String
  document       Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  text           String                       @db.Text
  chunkType      ChunkType                    @default(TEXT)
  positionIdx    Int                          @default(0)
  pageNumber     Int?
  section        String?
  tokenCount     Int                          @default(0)
  metadata       Json?                        @default("{}")
  embedding      Unsupported("vector(3072)")?
  createdAt      DateTime                     @default(now())

  @@index([documentId])
  @@index([organizationId])
}

enum CoverageStatus {
  COVERED
  PARTIALLY_COVERED
  MISSING
  UNKNOWN
}

enum RequirementCategory {
  FUNCTIONAL
  TECHNICAL
  BUSINESS
  COMPLIANCE
  SECURITY
  FINANCIAL
  TIMELINE
  DELIVERABLE
  EVALUATION
  MANDATORY
  OPTIONAL
  RISK
  ASSUMPTION
}

enum RequirementPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Requirement {
  id             String              @id @default(uuid())
  organizationId String?
  organization   Organization?       @relation(fields: [organizationId], references: [id])
  documentId     String
  document       Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  text           String              @db.Text
  category       RequirementCategory
  priority       RequirementPriority
  confidence     Int                 @default(0)
  pageNumber     Int?
  evidence       String              @db.Text

  coverageStatus     CoverageStatus?
  coverageScore      Int?
  coverageEvidence   String?         @db.Text
  matchedDocumentIds String[]

  gaps Gap[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([documentId, coverageStatus])
  @@index([documentId, category])
  @@index([organizationId])
}

enum GapSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GapCategory {
  CAPABILITY
  CERTIFICATION
  DOCUMENT
  EXPERIENCE
  COMPLIANCE
  TEAM
  TECHNICAL
  OTHER
}

model Gap {
  id             String        @id @default(uuid())
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String?
  document       Document?     @relation(fields: [documentId], references: [id])

  title                String
  description          String       @db.Text
  category             GapCategory
  severity             GapSeverity
  suggestedResolution  String       @db.Text
  relatedRequirementId String?
  relatedRequirement   Requirement? @relation(fields: [relatedRequirementId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([documentId])
}

enum DecisionRecommendation {
  GO
  NO_GO
  CONDITIONAL_GO
}

enum DecisionStatus {
  DRAFT
  APPROVED
  REJECTED
  NEEDS_REVIEW
}

model Decision {
  id             String        @id @default(uuid())
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String?       @unique
  document       Document?     @relation(fields: [documentId], references: [id])

  recommendation DecisionRecommendation
  status         DecisionStatus         @default(DRAFT)

  executiveSummary String @db.Text
  businessImpact   String @db.Text
  technicalRisk    String @db.Text
  complianceRisk   String @db.Text
  timelineRisk     String @db.Text
  financialRisk    String @db.Text

  confidence                Int    @default(0)
  supportingEvidence        String @db.Text
  counterarguments          String @db.Text
  alternativeRecommendation String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
}

model ExecutiveSummary {
  id             String        @id @default(uuid())
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String?       @unique
  document       Document?     @relation(fields: [documentId], references: [id])

  executiveSummary       String @db.Text
  projectOverview        String @db.Text
  keyRequirements        String @db.Text
  topRisks               String @db.Text
  topOpportunities       String @db.Text
  estimatedEffort        String @db.Text
  complianceStatus       String @db.Text
  businessRecommendation String @db.Text
  evidenceReferences     Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
}

enum ProposalStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

model Proposal {
  id             String        @id @default(uuid())
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  documentId     String?       @unique
  document       Document?     @relation(fields: [documentId], references: [id])

  title  String
  status ProposalStatus @default(DRAFT)

  sections         ProposalSection[]
  approvalRequests ApprovalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([documentId])
  @@index([projectId])
}

model ProposalSection {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  proposalId     String
  proposal       Proposal      @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  title   String
  content String @db.Text
  order   Int

  aiPrompt       String? @db.Text
  versionHistory Json?   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proposalId])
  @@index([organizationId])
}

model ApprovalRequest {
  id             String            @id @default(uuid())
  organizationId String?
  organization   Organization?     @relation(fields: [organizationId], references: [id])
  proposalId     String
  proposal       Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  reviewerId     String
  reviewer       User              @relation(fields: [reviewerId], references: [id])
  status         String            @default("PENDING") // PENDING, APPROVED, REJECTED
  comments       ApprovalComment[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([proposalId])
  @@index([organizationId])
}

model ApprovalComment {
  id             String          @id @default(uuid())
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  requestId      String
  request        ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  content        String          @db.Text
  createdAt      DateTime        @default(now())

  @@index([requestId])
  @@index([organizationId])
}

model AuditLog {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  action         String
  entityType     String // e.g., "PROPOSAL", "APPROVAL"
  entityId       String
  before         Json?
  after          Json?

  ipAddress String?
  metadata  Json?   @default("{}")

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([entityId])
  @@index([action])
}

enum NotificationType {
  DOCUMENT_PROCESSED
  AI_COMPLETED
  APPROVAL_REQUIRED
  REVIEW_COMPLETED
  PROJECT_UPDATE
}

model Notification {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  type           NotificationType
  title          String
  message        String           @db.Text
  link           String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
}

model NotificationPreference {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppEnabled   Boolean       @default(true)
  emailEnabled   Boolean       @default(false)
  disabledTypes  String[]      @default([]) // Array of NotificationType strings

  @@index([organizationId])
}

model SearchHistory {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  query          String
  createdAt      DateTime @default(now())

  @@index([userId])
}

model SavedSearch {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  name           String
  query          String
  filters        Json?    @default("{}")
  createdAt      DateTime @default(now())

  @@index([userId])
}

enum ExportFormat {
  PDF
  DOCX
  MARKDOWN
  CSV
  JSON
}

enum ExportType {
  EXECUTIVE_SUMMARY
  PROPOSAL
  GAP_ANALYSIS
  DECISION_REPORT
  COMPLIANCE_REPORT
}

model ExportJob {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentId     String?
  type           ExportType
  format         ExportFormat
  status         JobStatus     @default(PENDING)
  progress       Int           @default(0)
  fileUrl        String? // Storage path or JSON data if small
  error          String?       @db.Text
  createdAt      DateTime      @default(now())
  completedAt    DateTime?

  @@index([userId])
  @@index([organizationId])
}

enum ConnectorType {
  WEB_SCRAPER
  GITHUB
  GOOGLE_DRIVE
  SLACK
  JIRA
}

model Connector {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           ConnectorType
  name           String
  config         Json          @default("{}") // e.g., URLs, repos
  status         String        @default("ACTIVE") // ACTIVE, PAUSED, ERROR
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  jobs           SyncJob[]
  documents      Document[]    @relation("ConnectorDocuments")

  @@index([organizationId])
}

model SyncJob {
  id             String        @id @default(uuid())
  connectorId    String
  connector      Connector     @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  status         JobStatus     @default(PENDING)
  docsProcessed  Int           @default(0)
  docsAdded      Int           @default(0)
  docsUpdated    Int           @default(0)
  error          String?       @db.Text
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([connectorId])
}

model ChatSession {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])
  title          String        @default("New Chat")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]

  @@index([userId])
  @@index([organizationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatMessage {
  id             String           @id @default(uuid())
  sessionId      String
  session        ChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String           @db.Text
  createdAt      DateTime         @default(now())
  citations      MessageCitation[]

  @@index([sessionId])
}

model MessageCitation {
  id             String        @id @default(uuid())
  messageId      String
  message        ChatMessage   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  documentId     String
  document       Document      @relation(fields: [documentId], references: [id])
  chunkId        String?
  pageNumber     Int?
  snippet        String?       @db.Text
  link           String?

  @@index([messageId])
  @@index([documentId])
}

model Agent {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  promptId       String?
  modelSettingId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model PromptTemplate {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  systemPrompt   String        @db.Text
  userPrompt     String        @db.Text
  variables      Json          @default("[]")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model Workflow {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  status         String        @default("DRAFT")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  nodes          WorkflowNode[]
  edges          WorkflowEdge[]
  runs           WorkflowRun[]

  @@index([organizationId])
}

model WorkflowNode {
  id             String        @id @default(uuid())
  workflowId     String
  workflow       Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type           String        
  title          String
  config         Json          @default("{}")
  positionX      Float         @default(0)
  positionY      Float         @default(0)

  @@index([workflowId])
}

model WorkflowEdge {
  id             String        @id @default(uuid())
  workflowId     String
  workflow       Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNodeId   String
  targetNodeId   String
  condition      String?

  @@index([workflowId])
}

model ModelSetting {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String        
  modelName      String        
  apiKeysEnc     String?       
  config         Json          @default("{}") 
  createdAt      DateTime      @default(now())

  @@index([organizationId])
}

model ProjectDocument {
  id             String        @id @default(uuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId     String
  document       Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  addedById      String?
  createdAt      DateTime      @default(now())

  @@unique([projectId, documentId])
  @@index([projectId])
  @@index([documentId])
}

model WorkflowRun {
  id             String        @id @default(uuid())
  workflowId     String
  workflow       Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status         String        @default("RUNNING") 
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  errorMessage   String?       @db.Text
  traces         WorkflowTrace[]

  @@index([workflowId])
}

model WorkflowTrace {
  id             String        @id @default(uuid())
  runId          String
  run            WorkflowRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId         String        
  nodeType       String        
  inputs         Json          @default("{}")
  outputs        Json          @default("{}")
  executionTimeMs Int          @default(0)
  error          String?       @db.Text
  createdAt      DateTime      @default(now())

  @@index([runId])
  @@index([nodeId])
}

model GraphEntity {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentId      String?
  document        Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  name            String
  type            String        // e.g., "DOCUMENT", "EMPLOYEE", "DEPARTMENT", "PROJECT", "BUDGET", "DECISION", "MEETING", "CONTRACT", "CUSTOMER", "INVOICE", "VENDOR", "POLICY", "COMPLIANCE_REQUIREMENT", "SOP", "REPORT"
  description     String        @db.Text
  metadata        Json?         @default("{}") // summary, keywords, timeline, topics
  properties      Json?         @default("{}") // entity specific attributes
  confidenceScore Float         @default(1.0)
  sourceReferences Json?        @default("[]")
  embedding       Unsupported("vector(1536)")?

  sourceRelations GraphRelationship[] @relation("SourceEntity")
  targetRelations GraphRelationship[] @relation("TargetEntity")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([name])
  @@index([type])
  @@index([documentId])
}

model GraphRelationship {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentId      String?
  document        Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  
  sourceEntityId  String
  sourceEntity    GraphEntity   @relation("SourceEntity", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  
  targetEntityId  String
  targetEntity    GraphEntity   @relation("TargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)
  
  relationType    String        // e.g., "BELONGS_TO", "HAS_BUDGET", "SIGNED_BY", "APPLIES_TO", "ISSUED_BY"
  description     String        @db.Text
  evidence        String?       @db.Text
  confidenceScore Float         @default(1.0)
  
  createdAt       DateTime      @default(now())

  @@index([organizationId])
  @@index([sourceEntityId])
  @@index([targetEntityId])
  @@index([documentId])
}
